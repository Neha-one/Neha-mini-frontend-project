<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Generate Data</title>
    <link rel="stylesheet" href="/output.css">
</head>

<body>
    <button class=" bg-blue-500 text-white  rounded-full p-4">Generate Data</button>
</body>
<script>
    const button = document.querySelector('button').addEventListener('click', async () => {
        const showData = await fetch('/generate');
        const data = await showData.json();
        console.log(data);
        console.log(data.data);

        alert('Data Generated Successfully. Check console for details.');

    })

</script>

</html>